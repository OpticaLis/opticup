#!/usr/bin/env bash
# Run verifiers and capture their exit codes.
# Exit code contract for both gates:
#   0 = clean — allow commit
#   1 = violations — BLOCK commit
#   2 = warnings only — allow commit (informational)
#   * = any other error (e.g. missing node, broken check) — BLOCK commit
# Note: do NOT wrap a verifier in `if ! cmd`. Bash's `!` inverts the exit
# code seen by `$?` inside the branch, which caused a real corruption
# (286 NUL bytes in crm.html) to slip past this hook on 2026-04-21.
# Husky's wrapper (.husky/_/h) invokes this via `sh -e`, which propagates
# errexit into this script. Disable it so `status=$?` can run after a
# non-zero verifier exit — otherwise exit 2 (warnings) kills the hook
# before the allow-on-2 branch below is reached.
set +e

# Gate 1: whole-tree integrity (Iron Rule 31) — catches null-byte
# corruption that existed before staging. Uses git status --porcelain /
# ls-files for discovery; never a raw filesystem walk.
node scripts/verify-tree-integrity.mjs --fast
integrity_status=$?
if [ "$integrity_status" -ne 0 ] && [ "$integrity_status" -ne 2 ]; then
  echo "" >&2
  echo "pre-commit: verify-tree-integrity.mjs exited $integrity_status — commit blocked. Iron Rule 31 violation." >&2
  exit "$integrity_status"
fi

# Gate 2: staged-file rule check (verify.mjs) — file size, rule-14/15/18,
# orphan detection, secret scan.
node scripts/verify.mjs --staged
status=$?

if [ "$status" -eq 0 ] || [ "$status" -eq 2 ]; then
  exit 0
fi

echo "" >&2
echo "pre-commit: verify.mjs exited $status — commit blocked." >&2
exit "$status"
