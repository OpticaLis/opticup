---
import type { Locale } from '../i18n';
import { t } from '../i18n';

interface Props {
  locale: Locale;
  product: {
    id: string;
    barcode: string;
    brand_name: string;
    model: string;
    color?: string | null;
    quantity?: number;
    sell_price?: number | null;
    sell_discount?: number | null;
    default_sync?: 'full' | 'display';
    images: any;
  };
}

const { locale, product } = Astro.props;

// images can be string[], JSON string, or null — normalize
const imgArr: string[] = Array.isArray(product.images)
  ? product.images.map((x: any) => typeof x === 'string' ? x : x?.url).filter(Boolean)
  : [];
const mainImage = imgArr[0] ?? '/placeholder-product.svg';

const showPrice = product.sell_price && product.sell_price > 0;
const hasDiscount = (product.sell_discount ?? 0) > 0;
const finalPrice = hasDiscount ? product.sell_price! * (1 - product.sell_discount!) : product.sell_price;
const isOutOfStock = product.quantity !== undefined && product.quantity <= 0;
---

<article class="group bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow duration-300 relative">
  <a href={`/products/${product.barcode}`} class="block">
    <div class="aspect-square overflow-hidden bg-white relative">
      <img
        src={mainImage}
        alt={`${product.brand_name} ${product.model}`}
        class:list={[
          'w-full h-full object-contain group-hover:scale-105 transition-transform duration-300',
          isOutOfStock && 'opacity-40 grayscale'
        ]}
        loading="lazy"
      />
      {isOutOfStock && (
        <div class="absolute inset-0 flex flex-col items-center justify-center bg-white/60 backdrop-blur-[2px]">
          <span class="text-sm font-semibold text-gray-700 mb-2">
            {t(locale, 'product.outOfStock')}
          </span>
          <span class="text-xs px-3 py-1.5 rounded-full border border-gray-400 text-gray-600">
            {t(locale, 'product.notifyMe')}
          </span>
        </div>
      )}
    </div>
    <div class="p-4">
      <p class="text-xs font-medium uppercase tracking-wider text-gray-400 mb-1">
        {product.brand_name}
      </p>
      <h3 class="text-sm font-semibold text-gray-900 mb-1 line-clamp-2">
        {product.model}
      </h3>
      {product.color && (
        <p class="text-xs text-gray-500">{product.color}</p>
      )}
      <div class="mt-3 flex items-center justify-between">
        {showPrice ? (
          <div class="flex items-center gap-2 flex-wrap">
            {hasDiscount && (
              <span class="text-sm text-red-500 line-through">
                &#8362;{product.sell_price?.toLocaleString()}
              </span>
            )}
            <span class="text-lg font-bold" style="color: var(--color-primary);">
              &#8362;{Math.round(finalPrice!).toLocaleString()}
            </span>
          </div>
        ) : (
          <span class="text-sm text-gray-500">
            {t(locale, 'product.askOnWhatsApp')}
          </span>
        )}
      </div>
    </div>
  </a>
</article>
