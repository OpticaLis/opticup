---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { resolveTenant, getThemeCSS } from '../../lib/tenant';
import { getBrandBySlug } from '../../lib/brands';
import { getStorefrontProducts } from '../../lib/products';
import { t } from '../../i18n';
import type { Locale } from '../../i18n';

const locale: Locale = 'he';
const { slug } = Astro.params;

let tenant = null;
let brand = null;
let products: any[] = [];
let total = 0;

const url = Astro.url;
const page = parseInt(url.searchParams.get('page') || '1');
const perPage = 24;

try {
  tenant = await resolveTenant();
  if (tenant && slug) {
    brand = await getBrandBySlug(tenant.id, slug);
    if (brand) {
      const result = await getStorefrontProducts(tenant.id, {
        brand: brand.brand_name,
        limit: perPage,
        offset: (page - 1) * perPage,
      });
      products = result.products;
      total = result.total;
    }
  }
} catch (e) {
  console.warn('Supabase error:', (e as Error).message);
}

if (!brand) {
  return Astro.redirect('/brands');
}

const tenantName = tenant?.name ?? 'Optic Up';
const themeCSS = tenant ? getThemeCSS(tenant.storefront.theme) : '';
const totalPages = Math.ceil(total / perPage);

const pageNumbers: number[] = [];
const maxPages = Math.min(totalPages, 7);
for (let i = 0; i < maxPages; i++) {
  if (totalPages <= 7) pageNumbers.push(i + 1);
  else if (page <= 4) pageNumbers.push(i + 1);
  else if (page >= totalPages - 3) pageNumbers.push(totalPages - 6 + i);
  else pageNumbers.push(page - 3 + i);
}
const showPrev = page > 1;
const showNext = page < totalPages;
const hasPagination = totalPages > 1;
---

<BaseLayout
  title={`${brand.brand_name} — ${tenantName}`}
  description={`${brand.brand_name} — ${brand.product_count} ${t(locale, 'brands.productsCount')}`}
  locale={locale}
  tenantName={tenantName}
  tenantLogo={tenant?.storefront.logo_url}
  themeCSS={themeCSS}
  phone={tenant?.phone}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-gray-700">{t(locale, 'nav.home')}</a>
      <span class="mx-2">/</span>
      <a href="/brands" class="hover:text-gray-700">{t(locale, 'products.brands')}</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{brand.brand_name}</span>
    </nav>

    <!-- Brand header -->
    <div class="flex items-center gap-4 mb-8">
      <div
        class="w-16 h-16 rounded-full flex items-center justify-center text-white text-2xl font-bold shrink-0"
        style="background: var(--color-primary);"
      >
        {brand.brand_name.charAt(0).toUpperCase()}
      </div>
      <div>
        <h1 class="text-3xl font-bold text-gray-900">{brand.brand_name}</h1>
        <p class="text-gray-500">
          {total} {t(locale, 'products.items')}
        </p>
      </div>
    </div>

    {/* Product grid */}
    {products.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {products.map((product: any) => (
          <ProductCard locale={locale} product={product} />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-500 text-lg">{t(locale, 'products.noResults')}</p>
      </div>
    )}

    {/* Pagination */}
    {hasPagination && (
      <nav class="flex items-center justify-center gap-2 mt-10">
        {showPrev && (
          <a
            href={`/brands/${slug}?page=${page - 1}`}
            class="px-3 py-2 rounded-lg border border-gray-300 text-sm text-gray-700 hover:bg-gray-50"
          >
            {t(locale, 'products.prev')}
          </a>
        )}
        {pageNumbers.map((p) => (
          <a
            href={`/brands/${slug}?page=${p}`}
            class:list={[
              'px-3 py-2 rounded-lg text-sm font-medium',
              p === page
                ? 'text-white'
                : 'border border-gray-300 text-gray-700 hover:bg-gray-50'
            ]}
            style={p === page ? 'background: var(--color-primary);' : ''}
          >
            {p}
          </a>
        ))}
        {showNext && (
          <a
            href={`/brands/${slug}?page=${page + 1}`}
            class="px-3 py-2 rounded-lg border border-gray-300 text-sm text-gray-700 hover:bg-gray-50"
          >
            {t(locale, 'products.next')}
          </a>
        )}
      </nav>
    )}
  </div>
</BaseLayout>
