---
import type { Locale } from '../i18n';
import { t } from '../i18n';

interface Props {
  locale: Locale;
  tenantName: string;
}

const { locale, tenantName } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-300 mt-auto">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <h3 class="text-lg font-bold text-white mb-3">{tenantName}</h3>
        <p class="text-sm text-gray-400">
          {t(locale, 'hero.subtitle')}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">
          {t(locale, 'nav.products')}
        </h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/products" class="hover:text-white transition-colors">{t(locale, 'nav.products')}</a></li>
          <li><a href="/categories" class="hover:text-white transition-colors">{t(locale, 'nav.categories')}</a></li>
          <li><a href="/blog" class="hover:text-white transition-colors">{t(locale, 'nav.blog')}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-sm font-semibold text-white uppercase tracking-wider mb-3">
          {t(locale, 'nav.contact')}
        </h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/contact" class="hover:text-white transition-colors">{t(locale, 'nav.contact')}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-gray-700 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-gray-500">
      <span>&copy; {year} {tenantName}. {t(locale, 'footer.rights')}.</span>
      <span>{t(locale, 'footer.poweredBy')}</span>
    </div>
  </div>
</footer>
