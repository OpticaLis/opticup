---
import type { Locale } from '../i18n';
import { t, locales, getLangName } from '../i18n';
import SearchBar from './SearchBar.astro';

interface Props {
  locale: Locale;
  tenantName: string;
  tenantLogo?: string | null;
  phone?: string | null;
}

const { locale, tenantName, tenantLogo, phone } = Astro.props;
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-gray-200 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo + Name -->
      <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
        {tenantLogo ? (
          <img src={tenantLogo} alt={tenantName} class="h-10 w-auto" />
        ) : (
          <span class="text-2xl font-bold" style="color: var(--color-primary)">
            {tenantName}
          </span>
        )}
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6">
        <a href="/" class="text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors">
          {t(locale, 'nav.home')}
        </a>
        <a href="/products" class="text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors">
          {t(locale, 'nav.products')}
        </a>
        <a href="/categories" class="text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors">
          {t(locale, 'nav.categories')}
        </a>
        <a href="/brands" class="text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors">
          {t(locale, 'products.brands')}
        </a>
        <a href="/blog" class="text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors">
          {t(locale, 'nav.blog')}
        </a>
        <a href="/contact" class="text-sm font-medium text-gray-700 hover:text-gray-900 transition-colors">
          {t(locale, 'nav.contact')}
        </a>
      </nav>

      <!-- Search (desktop) -->
      <div class="hidden md:block w-64">
        <SearchBar locale={locale} />
      </div>

      <!-- Right side: language + phone + mobile menu -->
      <div class="flex items-center gap-4">
        <!-- Language Switcher -->
        <div class="hidden sm:flex items-center gap-1 text-xs">
          {locales.map((loc) => (
            <a
              href={loc === 'he' ? currentPath : `/${loc}${currentPath}`}
              class:list={[
                'px-2 py-1 rounded transition-colors',
                loc === locale
                  ? 'bg-gray-900 text-white'
                  : 'text-gray-500 hover:text-gray-900 hover:bg-gray-100',
              ]}
            >
              {getLangName(loc)}
            </a>
          ))}
        </div>

        <!-- Phone CTA -->
        {phone && (
          <a
            href={`tel:${phone}`}
            class="hidden sm:inline-flex items-center gap-1 text-sm font-medium px-3 py-1.5 rounded-full transition-colors"
            style="background: var(--color-primary); color: white;"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            {phone}
          </a>
        )}

        <!-- Mobile Menu Button -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-md text-gray-700 hover:bg-gray-100"
          aria-label="Toggle menu"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Nav -->
    <nav id="mobile-menu" class="hidden md:hidden pb-4 border-t border-gray-100 pt-3">
      <!-- Mobile Search -->
      <div class="px-3 mb-3">
        <SearchBar locale={locale} />
      </div>
      <div class="flex flex-col gap-2">
        <a href="/" class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:bg-gray-50">
          {t(locale, 'nav.home')}
        </a>
        <a href="/products" class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:bg-gray-50">
          {t(locale, 'nav.products')}
        </a>
        <a href="/categories" class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:bg-gray-50">
          {t(locale, 'nav.categories')}
        </a>
        <a href="/brands" class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:bg-gray-50">
          {t(locale, 'products.brands')}
        </a>
        <a href="/blog" class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:bg-gray-50">
          {t(locale, 'nav.blog')}
        </a>
        <a href="/contact" class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:bg-gray-50">
          {t(locale, 'nav.contact')}
        </a>
      </div>

      <!-- Mobile Language Switcher -->
      <div class="flex items-center gap-2 px-3 mt-3 pt-3 border-t border-gray-100">
        {locales.map((loc) => (
          <a
            href={loc === 'he' ? currentPath : `/${loc}${currentPath}`}
            class:list={[
              'px-3 py-1.5 rounded text-sm',
              loc === locale
                ? 'bg-gray-900 text-white'
                : 'text-gray-500 hover:text-gray-900 hover:bg-gray-100',
            ]}
          >
            {getLangName(loc)}
          </a>
        ))}
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
