---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { resolveTenant, getThemeCSS } from '../../lib/tenant';
import { getBrands } from '../../lib/brands';
import { t } from '../../i18n';
import type { Locale } from '../../i18n';

const locale: Locale = 'he';

let tenant = null;
let brands: Awaited<ReturnType<typeof getBrands>> = [];

try {
  tenant = await resolveTenant();
  if (tenant) {
    brands = await getBrands(tenant.id);
  }
} catch (e) {
  console.warn('Supabase error:', (e as Error).message);
}

const tenantName = tenant?.name ?? 'Optic Up';
const themeCSS = tenant ? getThemeCSS(tenant.storefront.theme) : '';
---

<BaseLayout
  title={`${t(locale, 'brands.title')} — ${tenantName}`}
  description={t(locale, 'brands.browseAll')}
  locale={locale}
  tenantName={tenantName}
  tenantLogo={tenant?.storefront.logo_url}
  themeCSS={themeCSS}
  phone={tenant?.phone}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-gray-700">{t(locale, 'nav.home')}</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{t(locale, 'products.brands')}</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-8">{t(locale, 'brands.title')}</h1>

    {brands.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {brands.map((brand) => (
          <a
            href={`/brands/${brand.slug}`}
            class="group bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg hover:border-gray-300 transition-all duration-300 text-center"
          >
            <div
              class="w-16 h-16 mx-auto mb-4 rounded-full flex items-center justify-center text-white text-xl font-bold"
              style="background: var(--color-primary);"
            >
              {brand.brand_name.charAt(0).toUpperCase()}
            </div>
            <h2 class="text-base font-bold text-gray-900 group-hover:text-gray-700 transition-colors mb-1">
              {brand.brand_name}
            </h2>
            <p class="text-sm text-gray-500">
              {brand.product_count} {t(locale, 'brands.productsCount')}
            </p>
            <p class="text-sm font-medium mt-3 group-hover:translate-x-1 rtl:group-hover:-translate-x-1 transition-transform" style="color: var(--color-primary);">
              {t(locale, 'brands.viewProducts')} &rarr;
            </p>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-500 text-lg">{t(locale, 'brands.noBrands')}</p>
      </div>
    )}
  </div>
</BaseLayout>
