---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { resolveTenant, getThemeCSS } from '../../lib/tenant';
import { getStorefrontCategories } from '../../lib/products';
import { t } from '../../i18n';
import type { Locale } from '../../i18n';

const locale: Locale = 'he';

let tenant = null;
let categories: any[] = [];

try {
  tenant = await resolveTenant();
  if (tenant) {
    categories = await getStorefrontCategories(tenant.id);
  }
} catch (e) {
  console.warn('Supabase error:', (e as Error).message);
}

const tenantName = tenant?.name ?? 'Optic Up';
const themeCSS = tenant ? getThemeCSS(tenant.storefront.theme) : '';

const categoryIcons: Record<string, string> = {
  'משקפי שמש': '/icons/sunglasses.svg',
  'משקפי ראייה': '/icons/eyeglasses.svg',
  'עדשות מגע': '/icons/contacts.svg',
  'אביזרים': '/icons/accessories.svg',
};
---

<BaseLayout
  title={`${t(locale, 'nav.categories')} — ${tenantName}`}
  description={`${t(locale, 'categories.browseAll')} — ${tenantName}`}
  locale={locale}
  tenantName={tenantName}
  tenantLogo={tenant?.storefront.logo_url}
  themeCSS={themeCSS}
  phone={tenant?.phone}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-gray-700">{t(locale, 'nav.home')}</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{t(locale, 'nav.categories')}</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 mb-8">{t(locale, 'nav.categories')}</h1>

    {categories.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {categories.map((cat: any) => (
          <a
            href={`/category/${encodeURIComponent(cat.name.replace(/\s+/g, '-'))}`}
            class="group relative bg-white rounded-xl border border-gray-200 p-8 hover:shadow-lg hover:border-gray-300 transition-all duration-300"
          >
            <div class="flex items-center gap-4 mb-4">
              <div
                class="w-14 h-14 rounded-xl flex items-center justify-center text-white text-2xl"
                style="background: var(--color-primary);"
              >
                {cat.name === 'משקפי שמש' && '🕶️'}
                {cat.name === 'משקפי ראייה' && '👓'}
                {cat.name === 'עדשות מגע' && '👁️'}
                {cat.name === 'אביזרים' && '🧴'}
                {!['משקפי שמש', 'משקפי ראייה', 'עדשות מגע', 'אביזרים'].includes(cat.name) && '📦'}
              </div>
              <div>
                <h2 class="text-lg font-bold text-gray-900 group-hover:text-gray-700 transition-colors">
                  {cat.name}
                </h2>
                <p class="text-sm text-gray-500">
                  {cat.count} {t(locale, 'products.items')}
                </p>
              </div>
            </div>
            <div class="text-sm font-medium group-hover:translate-x-1 rtl:group-hover:-translate-x-1 transition-transform" style="color: var(--color-primary);">
              {t(locale, 'categories.viewAll')} →
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-gray-500 text-lg">{t(locale, 'categories.noCategories')}</p>
      </div>
    )}
  </div>
</BaseLayout>
