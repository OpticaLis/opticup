---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { resolveTenant, getThemeCSS } from '../../lib/tenant';
import { getStorefrontProducts, getStorefrontBrands } from '../../lib/products';
import { t } from '../../i18n';
import type { Locale } from '../../i18n';

const locale: Locale = 'he';
const { slug } = Astro.params;

// Decode slug back to category name (e.g. "משקפי-שמש" → "משקפי שמש")
const categoryName = slug ? decodeURIComponent(slug).replace(/-/g, ' ') : '';

let tenant = null;
let products: any[] = [];
let total = 0;
let brands: any[] = [];

const url = Astro.url;
const brand = url.searchParams.get('brand') || undefined;
const page = parseInt(url.searchParams.get('page') || '1');
const perPage = 24;

try {
  tenant = await resolveTenant();
  if (tenant && categoryName) {
    const result = await getStorefrontProducts(tenant.id, {
      category: categoryName,
      brand,
      limit: perPage,
      offset: (page - 1) * perPage,
    });
    products = result.products;
    total = result.total;
    brands = await getStorefrontBrands(tenant.id, categoryName);
  }
} catch (e) {
  console.warn('Supabase error:', (e as Error).message);
}

const tenantName = tenant?.name ?? 'Optic Up';
const themeCSS = tenant ? getThemeCSS(tenant.storefront.theme) : '';
const totalPages = Math.ceil(total / perPage);

function buildUrl(params: Record<string, string | undefined>) {
  const u = new URL(url);
  Object.entries(params).forEach(([k, v]) => {
    if (v) u.searchParams.set(k, v);
    else u.searchParams.delete(k);
  });
  return u.pathname + u.search;
}

const pageNumbers: number[] = [];
const maxPages = Math.min(totalPages, 7);
for (let i = 0; i < maxPages; i++) {
  if (totalPages <= 7) pageNumbers.push(i + 1);
  else if (page <= 4) pageNumbers.push(i + 1);
  else if (page >= totalPages - 3) pageNumbers.push(totalPages - 6 + i);
  else pageNumbers.push(page - 3 + i);
}
const showPrev = page > 1;
const showNext = page < totalPages;
const hasPagination = totalPages > 1;
---

<BaseLayout
  title={`${categoryName} — ${tenantName}`}
  description={`${categoryName} — ${total} ${t(locale, 'products.items')}`}
  locale={locale}
  tenantName={tenantName}
  tenantLogo={tenant?.storefront.logo_url}
  themeCSS={themeCSS}
  phone={tenant?.phone}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-gray-700">{t(locale, 'nav.home')}</a>
      <span class="mx-2">/</span>
      <a href="/categories" class="hover:text-gray-700">{t(locale, 'nav.categories')}</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{categoryName}</span>
    </nav>

    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">{categoryName}</h1>
        <p class="text-gray-500 mt-1">{total} {t(locale, 'products.items')}</p>
      </div>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Brand filter sidebar -->
      {brands.length > 1 && (
        <aside class="w-full lg:w-56 shrink-0">
          <div class="mb-6">
            <h3 class="text-sm font-semibold text-gray-900 mb-3">{t(locale, 'products.brands')}</h3>
            <div class="flex flex-col gap-1 max-h-64 overflow-y-auto">
              <a
                href={buildUrl({ brand: undefined, page: undefined })}
                class:list={[
                  'text-sm px-3 py-1.5 rounded transition-colors',
                  !brand ? 'bg-gray-100 font-medium text-gray-900' : 'text-gray-600 hover:bg-gray-50'
                ]}
              >
                {t(locale, 'products.allBrands')}
              </a>
              {brands.map((b: any) => (
                <a
                  href={buildUrl({ brand: b.brand_name, page: undefined })}
                  class:list={[
                    'text-sm px-3 py-1.5 rounded transition-colors flex justify-between',
                    brand === b.brand_name ? 'bg-gray-100 font-medium text-gray-900' : 'text-gray-600 hover:bg-gray-50'
                  ]}
                >
                  <span>{b.brand_name}</span>
                  <span class="text-gray-400">{b.count}</span>
                </a>
              ))}
            </div>
          </div>

          {(brand) && (
            <a
              href={`/category/${slug}`}
              class="inline-flex items-center gap-1 text-sm text-red-600 hover:text-red-700"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
              {t(locale, 'products.clearFilters')}
            </a>
          )}
        </aside>
      )}

      <!-- Product grid -->
      <div class="flex-1">
        {products.length > 0 ? (
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
            {products.map((product: any) => (
              <ProductCard locale={locale} product={product} />
            ))}
          </div>
        ) : (
          <div class="text-center py-16">
            <p class="text-gray-500 text-lg">{t(locale, 'products.noResults')}</p>
            <a href="/categories" class="mt-4 inline-block text-sm underline" style="color: var(--color-primary);">
              {t(locale, 'categories.browseAll')}
            </a>
          </div>
        )}

        {/* Pagination */}
        {hasPagination && (
          <nav class="flex items-center justify-center gap-2 mt-10">
            {showPrev && (
              <a
                href={buildUrl({ page: String(page - 1) })}
                class="px-3 py-2 rounded-lg border border-gray-300 text-sm text-gray-700 hover:bg-gray-50"
              >
                {t(locale, 'products.prev')}
              </a>
            )}
            {pageNumbers.map((p) => (
              <a
                href={buildUrl({ page: String(p) })}
                class:list={[
                  'px-3 py-2 rounded-lg text-sm font-medium',
                  p === page
                    ? 'text-white'
                    : 'border border-gray-300 text-gray-700 hover:bg-gray-50'
                ]}
                style={p === page ? 'background: var(--color-primary);' : ''}
              >
                {p}
              </a>
            ))}
            {showNext && (
              <a
                href={buildUrl({ page: String(page + 1) })}
                class="px-3 py-2 rounded-lg border border-gray-300 text-sm text-gray-700 hover:bg-gray-50"
              >
                {t(locale, 'products.next')}
              </a>
            )}
          </nav>
        )}
      </div>
    </div>
  </div>
</BaseLayout>
