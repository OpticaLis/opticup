---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { resolveTenant, getThemeCSS } from '../../lib/tenant';
import { getProductByBarcode, getRelatedProducts } from '../../lib/products';
import { t } from '../../i18n';
import type { Locale } from '../../i18n';

const locale: Locale = 'he';
const { barcode } = Astro.params;

let tenant = null;
let product = null;
let related: any[] = [];

try {
  tenant = await resolveTenant();
  if (tenant && barcode) {
    product = await getProductByBarcode(tenant.id, barcode);
    if (product) {
      related = await getRelatedProducts(tenant.id, product, 4);
    }
  }
} catch (e) {
  console.warn('Supabase error:', (e as Error).message);
}

if (!product) {
  return Astro.redirect('/products');
}

const tenantName = tenant?.name ?? 'Optic Up';
const themeCSS = tenant ? getThemeCSS(tenant.storefront.theme) : '';

// Normalize images — handle string[], object[], or null
const rawImages = Array.isArray(product.images) ? product.images : [];
const images: string[] = rawImages
  .map((x: any) => typeof x === 'string' ? x : x?.url)
  .filter(Boolean);
const mainImage = images[0] ?? '/placeholder-product.svg';
const hasMultipleImages = images.length > 1;

const showPrice = product.sell_price && product.sell_price > 0;
const hasDiscount = (product.sell_discount ?? 0) > 0;
const finalPrice = hasDiscount ? product.sell_price! * (1 - product.sell_discount!) : product.sell_price;
const phone = tenant?.phone ?? '';
const whatsappMsg = encodeURIComponent(
  `היי, ראיתי באתר את ${product.brand_name} ${product.model} ואשמח לפרטים`
);
const whatsappUrl = `https://wa.me/${phone?.replace(/[^0-9]/g, '')}?text=${whatsappMsg}`;

const specs = [
  { label: t(locale, 'product.brand'), value: product.brand_name },
  { label: t(locale, 'product.model'), value: product.model },
  product.color && { label: t(locale, 'product.color'), value: product.color },
  product.size && { label: t(locale, 'product.size'), value: product.size },
  product.product_type && { label: t(locale, 'product.type'), value: product.product_type },
  product.barcode && { label: t(locale, 'product.barcode'), value: product.barcode },
].filter(Boolean);

const isOutOfStock = product.quantity <= 0;

// Schema.org Product JSON-LD
const productJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": `${product.brand_name} ${product.model}`,
  "description": `${product.brand_name} ${product.model}`,
  "image": images.length ? images : undefined,
  "brand": { "@type": "Brand", "name": product.brand_name },
  "sku": product.barcode,
  ...(showPrice ? {
    "offers": {
      "@type": "Offer",
      "price": Math.round(finalPrice!),
      "priceCurrency": "ILS",
      "availability": product.quantity > 0
        ? "https://schema.org/InStock"
        : "https://schema.org/OutOfStock",
    }
  } : {}),
});

// Schema.org BreadcrumbList JSON-LD
const breadcrumbJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": t(locale, 'nav.home'), "item": "/" },
    { "@type": "ListItem", "position": 2, "name": t(locale, 'nav.products'), "item": "/products" },
    ...(product.product_type ? [{
      "@type": "ListItem",
      "position": 3,
      "name": product.product_type,
      "item": `/products?category=${encodeURIComponent(product.product_type)}`
    }] : []),
    {
      "@type": "ListItem",
      "position": product.product_type ? 4 : 3,
      "name": `${product.brand_name} ${product.model}`,
    }
  ]
});
---

<BaseLayout
  title={`${product.brand_name} ${product.model} — ${tenantName}`}
  description={`${product.brand_name} ${product.model} — ${tenantName}`}
  locale={locale}
  tenantName={tenantName}
  tenantLogo={tenant?.storefront.logo_url}
  themeCSS={themeCSS}
  phone={phone}
>
  <script type="application/ld+json" set:html={productJsonLd} />
  <script type="application/ld+json" set:html={breadcrumbJsonLd} />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-gray-700">{t(locale, 'nav.home')}</a>
      <span class="mx-2">/</span>
      <a href="/products" class="hover:text-gray-700">{t(locale, 'nav.products')}</a>
      {product.product_type && (
        <Fragment>
          <span class="mx-2">/</span>
          <a href={`/products?category=${encodeURIComponent(product.product_type)}`} class="hover:text-gray-700">
            {product.product_type}
          </a>
        </Fragment>
      )}
      <span class="mx-2">/</span>
      <span class="text-gray-900">{product.brand_name} {product.model}</span>
    </nav>

    <!-- Product section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">

      <!-- Image carousel -->
      <div id="gallery" data-images={JSON.stringify(images)}>
        <div class="relative aspect-square bg-white rounded-xl overflow-hidden border border-gray-200 mb-4">
          <img
            id="main-image"
            src={mainImage}
            alt={`${product.brand_name} ${product.model}`}
            class:list={[
              'w-full h-full object-contain cursor-zoom-in',
              isOutOfStock && 'opacity-40 grayscale'
            ]}
          />
          {isOutOfStock && (
            <div class="absolute inset-0 flex flex-col items-center justify-center bg-white/50 backdrop-blur-[2px] pointer-events-none">
              <span class="text-lg font-bold text-gray-800 mb-3">
                {t(locale, 'product.outOfStock')}
              </span>
              <span class="px-4 py-2 rounded-full border-2 border-gray-500 text-sm font-medium text-gray-700">
                {t(locale, 'product.notifyMe')}
              </span>
            </div>
          )}
          {/* Carousel arrows — only if multiple images */}
          {hasMultipleImages && (
            <Fragment>
              <button
                id="carousel-next"
                class="absolute top-1/2 right-3 -translate-y-1/2 w-10 h-10 rounded-full bg-white/80 hover:bg-white shadow flex items-center justify-center transition-colors"
                aria-label="Previous image"
              >
                <svg class="w-5 h-5 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </button>
              <button
                id="carousel-prev"
                class="absolute top-1/2 left-3 -translate-y-1/2 w-10 h-10 rounded-full bg-white/80 hover:bg-white shadow flex items-center justify-center transition-colors"
                aria-label="Next image"
              >
                <svg class="w-5 h-5 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                </svg>
              </button>
            </Fragment>
          )}
        </div>
        {/* Thumbnail strip */}
        {hasMultipleImages && (
          <div class="grid gap-2" style={`grid-template-columns: repeat(${Math.min(images.length, 6)}, 1fr);`}>
            {images.map((img: string, i: number) => (
              <button
                class:list={[
                  'aspect-square rounded-lg overflow-hidden border-2 cursor-pointer transition-all gallery-thumb',
                  i === 0 ? 'border-gray-900' : 'border-gray-200 hover:border-gray-400'
                ]}
                data-index={i}
              >
                <img src={img} alt="" class="w-full h-full object-contain" loading="lazy" />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Product info -->
      <div>
        <p class="text-sm font-medium uppercase tracking-wider text-gray-400 mb-2">
          {product.brand_name}
        </p>
        <h1 class="text-3xl font-bold text-gray-900 mb-4">
          {product.model}
        </h1>

        {product.color && (
          <p class="text-gray-600 mb-2">{t(locale, 'product.color')}: {product.color}</p>
        )}

        {/* Price */}
        <div class="mb-6">
          {showPrice ? (
            <div class="flex items-center gap-3 flex-wrap">
              {hasDiscount && (
                <span class="text-lg text-red-500 line-through">
                  ₪{product.sell_price?.toLocaleString()}
                </span>
              )}
              <span class="text-3xl font-bold" style="color: var(--color-primary);">
                ₪{Math.round(finalPrice!).toLocaleString()}
              </span>
            </div>
          ) : (
            <span class="text-lg text-gray-500">
              {t(locale, 'product.contactForPrice')}
            </span>
          )}
        </div>

        {/* Stock indicator */}
        <div class="mb-6">
          {product.quantity > 0 ? (
            <span class="inline-flex items-center gap-1.5 text-sm text-green-700 bg-green-50 px-3 py-1 rounded-full">
              <span class="w-2 h-2 bg-green-500 rounded-full"></span>
              {t(locale, 'product.inStock')}
            </span>
          ) : (
            <span class="inline-flex items-center gap-1.5 text-sm text-red-700 bg-red-50 px-3 py-1 rounded-full">
              <span class="w-2 h-2 bg-red-500 rounded-full"></span>
              {t(locale, 'product.outOfStock')}
            </span>
          )}
        </div>

        {/* CTA buttons */}
        <div class="flex flex-col sm:flex-row gap-3 mb-8">
          {phone && (
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl text-white font-medium text-base transition-opacity hover:opacity-90"
              style="background: #25D366;"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              {t(locale, 'product.whatsapp')}
            </a>
          )}
          {phone && (
            <a
              href={`tel:${phone}`}
              class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl border-2 font-medium text-base transition-colors hover:bg-gray-50"
              style="border-color: var(--color-primary); color: var(--color-primary);"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {t(locale, 'product.call')}
            </a>
          )}
        </div>

        {/* Specs table */}
        <div class="border border-gray-200 rounded-xl overflow-hidden">
          <h3 class="text-sm font-semibold text-gray-900 bg-gray-50 px-4 py-3 border-b border-gray-200">
            {t(locale, 'product.specs')}
          </h3>
          <dl class="divide-y divide-gray-100">
            {specs.map((spec: any) => (
              <div class="flex justify-between px-4 py-3">
                <dt class="text-sm text-gray-500">{spec.label}</dt>
                <dd class="text-sm font-medium text-gray-900">{spec.value}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>

    {/* Related products */}
    {related.length > 0 && (
      <section class="mt-16">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">
          {t(locale, 'product.related')}
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {related.map((p: any) => (
            <ProductCard locale={locale} product={p} />
          ))}
        </div>
      </section>
    )}
  </div>

  <!-- Lightbox overlay -->
  <div id="lightbox" class="fixed inset-0 z-50 hidden">
    <div class="absolute inset-0 bg-black/85" id="lightbox-backdrop"></div>
    <button id="lightbox-close" class="absolute top-4 right-4 z-10 w-10 h-10 rounded-full bg-white/20 hover:bg-white/40 flex items-center justify-center transition-colors" aria-label="Close">
      <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <div class="absolute inset-0 flex items-center justify-center p-4 sm:p-12 pointer-events-none">
      <img id="lightbox-image" src="" alt="" class="max-w-full max-h-full object-contain pointer-events-auto" />
    </div>
    <button id="lightbox-next" class="absolute top-1/2 right-4 -translate-y-1/2 w-12 h-12 rounded-full bg-white/20 hover:bg-white/40 flex items-center justify-center transition-colors" aria-label="Next">
      <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </button>
    <button id="lightbox-prev" class="absolute top-1/2 left-4 -translate-y-1/2 w-12 h-12 rounded-full bg-white/20 hover:bg-white/40 flex items-center justify-center transition-colors" aria-label="Previous">
      <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </button>
  </div>
</BaseLayout>

<script>
  const gallery = document.getElementById('gallery');
  const mainImg = document.getElementById('main-image') as HTMLImageElement;
  const thumbs = document.querySelectorAll('.gallery-thumb');
  const images: string[] = JSON.parse(gallery?.dataset.images ?? '[]');
  let currentIndex = 0;

  function showImage(index: number) {
    if (!images.length) return;
    currentIndex = (index + images.length) % images.length;
    if (mainImg) mainImg.src = images[currentIndex];
    thumbs.forEach((t, i) => {
      t.classList.toggle('border-gray-900', i === currentIndex);
      t.classList.toggle('border-gray-200', i !== currentIndex);
    });
  }

  // Thumbnail clicks
  thumbs.forEach(thumb => {
    thumb.addEventListener('click', () => {
      const idx = parseInt(thumb.getAttribute('data-index') ?? '0', 10);
      showImage(idx);
    });
  });

  // Carousel arrows (RTL: right = prev, left = next in visual terms, but arrows point correctly)
  document.getElementById('carousel-prev')?.addEventListener('click', () => showImage(currentIndex - 1));
  document.getElementById('carousel-next')?.addEventListener('click', () => showImage(currentIndex + 1));

  // Lightbox
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-image') as HTMLImageElement;

  function openLightbox(index: number) {
    currentIndex = index;
    if (lightboxImg) lightboxImg.src = images[currentIndex];
    lightbox?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    // Hide arrows if single image
    const showNav = images.length > 1;
    document.getElementById('lightbox-prev')?.classList.toggle('hidden', !showNav);
    document.getElementById('lightbox-next')?.classList.toggle('hidden', !showNav);
  }

  function closeLightbox() {
    lightbox?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  function lightboxNav(delta: number) {
    currentIndex = (currentIndex + delta + images.length) % images.length;
    if (lightboxImg) lightboxImg.src = images[currentIndex];
  }

  // Open lightbox on main image click
  mainImg?.addEventListener('click', () => {
    if (images.length) openLightbox(currentIndex);
  });

  document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
  document.getElementById('lightbox-backdrop')?.addEventListener('click', closeLightbox);
  document.getElementById('lightbox-prev')?.addEventListener('click', () => lightboxNav(-1));
  document.getElementById('lightbox-next')?.addEventListener('click', () => lightboxNav(1));

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (lightbox?.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') lightboxNav(1);  // RTL: left arrow goes forward
    if (e.key === 'ArrowRight') lightboxNav(-1); // RTL: right arrow goes backward
  });
</script>
