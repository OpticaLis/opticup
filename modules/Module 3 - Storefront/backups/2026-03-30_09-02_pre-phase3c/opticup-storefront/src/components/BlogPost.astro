---
import type { BlogPost } from '../data/blog-posts';
import type { Locale } from '../i18n';
import { t, getDir } from '../i18n';

interface Props {
  post: BlogPost;
  locale: Locale;
  relatedPosts?: BlogPost[];
  tenantName?: string;
}

const { post, locale, relatedPosts = [], tenantName = '' } = Astro.props;
const dir = getDir(locale);
const isRtl = dir === 'rtl';

// Format date per locale
function formatDate(dateStr: string, lang: string): string {
  const date = new Date(dateStr);
  const localeMap: Record<string, string> = { he: 'he-IL', en: 'en-US', ru: 'ru-RU' };
  return date.toLocaleDateString(localeMap[lang] || 'en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

// Schema.org Article JSON-LD
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  datePublished: post.date,
  dateModified: post.modified,
  author: {
    '@type': 'Organization',
    name: tenantName || 'Prizma Optic',
  },
  publisher: {
    '@type': 'Organization',
    name: tenantName || 'Prizma Optic',
  },
  ...(post.featuredImage && { image: post.featuredImage }),
  description: post.seo.description,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': Astro.url.href,
  },
};

const blogIndexUrl = locale === 'he' ? '/%D7%91%D7%9C%D7%95%D7%92/' : `/${locale}/blog/`;
const blogIndexLabel = locale === 'he' ? 'חזרה לבלוג' : locale === 'ru' ? 'Назад в блог' : 'Back to blog';
const shareText = encodeURIComponent(post.title);
const shareUrl = encodeURIComponent(Astro.url.href);
---

<article class={`max-w-4xl mx-auto px-4 py-8 ${isRtl ? 'text-right' : 'text-left'}`} dir={dir}>
  <!-- Breadcrumb -->
  <nav class="text-sm text-gray-500 mb-6" aria-label="breadcrumb">
    <a href="/" class="hover:text-blue-600">{locale === 'he' ? 'דף הבית' : locale === 'ru' ? 'Главная' : 'Home'}</a>
    <span class="mx-2">/</span>
    <a href={blogIndexUrl} class="hover:text-blue-600">{locale === 'he' ? 'בלוג' : locale === 'ru' ? 'Блог' : 'Blog'}</a>
    <span class="mx-2">/</span>
    <span class="text-gray-700">{post.title}</span>
  </nav>

  <!-- Title -->
  <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4 leading-tight">
    {post.title}
  </h1>

  <!-- Date & meta -->
  <div class="flex items-center gap-4 text-gray-500 text-sm mb-6">
    <time datetime={post.date}>{formatDate(post.date, locale)}</time>
    <span>·</span>
    <span>{post.wordCount} {locale === 'he' ? 'מילים' : locale === 'ru' ? 'слов' : 'words'}</span>
  </div>

  <!-- Featured image -->
  {post.featuredImage && (
    <div class="mb-8 rounded-lg overflow-hidden">
      <img
        src={post.featuredImage}
        alt={post.title}
        class="w-full h-auto object-cover max-h-[400px]"
        loading="eager"
      />
    </div>
  )}

  <!-- Content -->
  <div class="prose prose-lg max-w-none
    prose-headings:text-gray-900 prose-headings:font-bold
    prose-p:text-gray-700 prose-p:leading-relaxed
    prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline
    prose-img:rounded-lg prose-img:mx-auto
    prose-blockquote:border-blue-500 prose-blockquote:bg-blue-50 prose-blockquote:rounded
    mb-8">
    <Fragment set:html={post.content} />
  </div>

  <!-- Share buttons -->
  <div class={`flex items-center gap-3 border-t border-gray-200 pt-6 mb-8 ${isRtl ? 'flex-row-reverse' : ''}`}>
    <span class="text-sm font-medium text-gray-600">
      {locale === 'he' ? 'שתפו:' : locale === 'ru' ? 'Поделиться:' : 'Share:'}
    </span>
    <a
      href={`https://wa.me/?text=${shareText}%20${shareUrl}`}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-1 px-3 py-1.5 bg-green-500 text-white text-sm rounded-full hover:bg-green-600 transition"
    >
      WhatsApp
    </a>
    <a
      href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`}
      target="_blank"
      rel="noopener"
      class="inline-flex items-center gap-1 px-3 py-1.5 bg-blue-600 text-white text-sm rounded-full hover:bg-blue-700 transition"
    >
      Facebook
    </a>
  </div>

  <!-- Back to blog -->
  <a href={blogIndexUrl} class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-800 font-medium mb-8">
    {isRtl ? '→' : '←'} {blogIndexLabel}
  </a>

  <!-- Related posts -->
  {relatedPosts.length > 0 && (
    <div class="border-t border-gray-200 pt-8">
      <h2 class="text-xl font-bold text-gray-900 mb-4">
        {locale === 'he' ? 'כתבות נוספות' : locale === 'ru' ? 'Похожие статьи' : 'Related Articles'}
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {relatedPosts.map(related => {
          const relatedUrl = related.lang === 'he'
            ? `/${related.slug}/`
            : `/${related.lang}/${related.slug}/`;
          return (
            <a href={relatedUrl} class="block p-4 border border-gray-200 rounded-lg hover:shadow-md transition">
              {related.featuredImage && (
                <img src={related.featuredImage} alt={related.title} class="w-full h-32 object-cover rounded mb-3" loading="lazy" />
              )}
              <h3 class="font-semibold text-gray-900 line-clamp-2 mb-1">{related.title}</h3>
              <p class="text-sm text-gray-500">{formatDate(related.date, locale)}</p>
            </a>
          );
        })}
      </div>
    </div>
  )}
</article>

<!-- Schema.org -->
<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
