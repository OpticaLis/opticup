---
import type { Locale } from '../i18n';
import { t } from '../i18n';
import ProductCard from './ProductCard.astro';

interface Props {
  locale: Locale;
  products: Array<{
    id: string;
    barcode: string;
    brand_name: string;
    model: string;
    color?: string | null;
    sell_price?: number | null;
    sell_discount?: number | null;
    default_sync?: 'full' | 'display';
    images: any;
  }>;
}

const { locale, products } = Astro.props;
const hasProducts = products.length > 0;
---

<section class="py-14 sm:py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">
        {t(locale, 'nav.products')}
      </h2>
      <a
        href="/products"
        class="text-sm font-medium hover:underline"
        style="color: var(--color-primary);"
      >
        {t(locale, 'common.seeAll')} →
      </a>
    </div>

    {hasProducts ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
        {products.slice(0, 8).map((product) => (
          <ProductCard locale={locale} product={product} />
        ))}
      </div>
    ) : (
      <div class="text-center py-16 bg-gray-50 rounded-xl">
        <div class="text-4xl mb-3">👓</div>
        <p class="text-gray-500 text-lg mb-2">
          {locale === 'he' ? 'מוצרים יתווספו בקרוב' : locale === 'ru' ? 'Товары скоро появятся' : 'Products coming soon'}
        </p>
        <p class="text-gray-400 text-sm">
          {locale === 'he' ? 'אנחנו עובדים על הקטלוג שלנו' : locale === 'ru' ? 'Мы работаем над каталогом' : 'We are working on our catalog'}
        </p>
      </div>
    )}
  </div>
</section>
