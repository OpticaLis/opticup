---
import type { Locale } from '../i18n';
import { t } from '../i18n';

interface Props {
  locale: Locale;
  class?: string;
}

const { locale, class: className } = Astro.props;
---

<div class:list={['search-bar-wrapper relative', className]}>
  <form action="/products" method="get" class="relative">
    <input
      type="text"
      name="q"
      id="search-input"
      placeholder={t(locale, 'products.searchPlaceholder')}
      autocomplete="off"
      class="w-full px-4 py-2.5 pe-10 border border-gray-300 rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:border-transparent transition-all"
      style="focus:ring-color: var(--color-primary);"
    />
    <button
      type="submit"
      class="absolute top-1/2 -translate-y-1/2 end-3 text-gray-400 hover:text-gray-600"
      aria-label="Search"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
    </button>
  </form>

  <!-- Search results dropdown (populated by client JS) -->
  <div
    id="search-results"
    class="hidden absolute top-full left-0 right-0 mt-1 bg-white border border-gray-200 rounded-xl shadow-xl z-50 max-h-80 overflow-y-auto"
  >
  </div>
</div>

<script>
  const input = document.getElementById('search-input') as HTMLInputElement;
  const results = document.getElementById('search-results') as HTMLDivElement;
  let debounceTimer: ReturnType<typeof setTimeout>;

  if (input && results) {
    input.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      const q = input.value.trim();

      if (q.length < 2) {
        results.classList.add('hidden');
        results.innerHTML = '';
        return;
      }

      debounceTimer = setTimeout(async () => {
        try {
          // Dynamic import to avoid bundling Supabase in static pages
          const { createClient } = await import('@supabase/supabase-js');
          const url = import.meta.env.PUBLIC_SUPABASE_URL;
          const key = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
          if (!url || !key) return;

          const sb = createClient(url, key);
          const tenantSlug = import.meta.env.PUBLIC_DEFAULT_TENANT || 'prizma';

          // Get tenant ID
          const { data: tenant } = await sb
            .from('v_public_tenant')
            .select('id')
            .eq('slug', tenantSlug)
            .single();

          if (!tenant) return;

          const { data } = await sb
            .from('v_storefront_products')
            .select('barcode, brand_name, model, color, images, sell_price, sell_discount')
            .eq('tenant_id', tenant.id)
            .ilike('search_text', `%${q.toLowerCase()}%`)
            .limit(6);

          if (!data || data.length === 0) {
            results.innerHTML = `<div class="p-4 text-sm text-gray-500 text-center">לא נמצאו תוצאות</div>`;
            results.classList.remove('hidden');
            return;
          }

          results.innerHTML = data.map((p: any) => {
            const imgs = Array.isArray(p.images) ? p.images : [];
            const first = imgs[0];
            const img = (typeof first === 'string') ? first : (first?.url ?? '/placeholder-product.svg');
            const hasDiscount = (p.sell_discount ?? 0) > 0;
            const finalPrice = hasDiscount ? Math.round(p.sell_price * (1 - p.sell_discount)) : p.sell_price;
            const price = p.sell_price && p.sell_price > 0
              ? (hasDiscount
                ? `<span class="text-xs text-red-500 line-through">₪${p.sell_price}</span> <span class="text-sm font-bold">₪${finalPrice}</span>`
                : `<span class="text-sm font-bold">₪${p.sell_price}</span>`)
              : '';
            return `
              <a href="/products/${p.barcode}" class="flex items-center gap-3 p-3 hover:bg-gray-50 transition-colors">
                <img src="${img}" alt="" class="w-12 h-12 object-contain rounded bg-gray-50 shrink-0" />
                <div class="min-w-0 flex-1">
                  <p class="text-xs text-gray-400">${p.brand_name || ''}</p>
                  <p class="text-sm font-medium text-gray-900 truncate">${p.model || ''}</p>
                  ${p.color ? `<p class="text-xs text-gray-500">${p.color}</p>` : ''}
                </div>
                ${price}
              </a>
            `;
          }).join('');

          // Add "see all" link
          results.innerHTML += `
            <a href="/products?q=${encodeURIComponent(q)}" class="block p-3 text-center text-sm font-medium border-t border-gray-100 hover:bg-gray-50" style="color: var(--color-primary);">
              הצג את כל התוצאות
            </a>
          `;

          results.classList.remove('hidden');
        } catch (err) {
          console.warn('Search error:', err);
        }
      }, 300);
    });

    // Close on click outside
    document.addEventListener('click', (e) => {
      if (!(e.target as HTMLElement).closest('.search-bar-wrapper')) {
        results.classList.add('hidden');
      }
    });

    // Close on Escape
    input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        results.classList.add('hidden');
        input.blur();
      }
    });
  }
</script>
