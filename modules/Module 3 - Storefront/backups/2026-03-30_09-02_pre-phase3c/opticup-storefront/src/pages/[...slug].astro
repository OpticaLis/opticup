---
/**
 * Catch-all route for root-level Hebrew content.
 * Handles: blog posts, landing pages (Phase 3C).
 * Does NOT catch: /products/, /brands/, /categories/, /search, /api/
 * (Astro specific routes take priority over catch-all)
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogPostComponent from '../components/BlogPost.astro';
import { getPostBySlug, getRelatedPosts } from '../data/blog-posts';
import { resolveTenant } from '../lib/tenant';

const slugParam = Astro.params.slug;
if (!slugParam) return Astro.redirect('/');

// Decode the slug for matching
const slug = decodeURIComponent(slugParam);

// 1. Check if it's a Hebrew blog post
const post = getPostBySlug(slugParam, 'he') || getPostBySlug(slug, 'he');

// 2. TODO: Check if it's a landing page (Phase 3C)

// If nothing matched, return 404
if (!post) {
  return new Response('Not Found', { status: 404 });
}

// Resolve tenant for layout
const tenant = await resolveTenant();
const tenantName = tenant?.name || '';
const themeCSS = tenant?.storefront?.theme
  ? Object.entries(tenant.storefront.theme).map(([k, v]) => `--color-${k}: ${v};`).join(' ')
  : '';

const related = getRelatedPosts(post, 3);
---

<BaseLayout
  title={post.seo.title}
  description={post.seo.description}
  ogImage={post.seo.ogImage || undefined}
  locale="he"
  tenantName={tenantName}
  tenantLogo={tenant?.storefront?.logo_url}
  themeCSS={themeCSS}
  phone={tenant?.phone}
>
  <BlogPostComponent
    post={post}
    locale="he"
    relatedPosts={related}
    tenantName={tenantName}
  />
</BaseLayout>
