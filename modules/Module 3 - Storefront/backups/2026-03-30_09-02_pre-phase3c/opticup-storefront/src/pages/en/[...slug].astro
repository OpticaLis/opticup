---
/**
 * Catch-all route for English blog posts and landing pages.
 * URL: /en/[slug]/
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostComponent from '../../components/BlogPost.astro';
import { getPostBySlug, getRelatedPosts } from '../../data/blog-posts';
import { resolveTenant } from '../../lib/tenant';

const slugParam = Astro.params.slug;
if (!slugParam) return Astro.redirect('/en/');

const slug = decodeURIComponent(slugParam);
const post = getPostBySlug(slugParam, 'en') || getPostBySlug(slug, 'en');

// TODO: Check landing pages (Phase 3C)

if (!post) {
  return new Response('Not Found', { status: 404 });
}

const tenant = await resolveTenant();
const tenantName = tenant?.name || '';
const themeCSS = tenant?.storefront?.theme
  ? Object.entries(tenant.storefront.theme).map(([k, v]) => `--color-${k}: ${v};`).join(' ')
  : '';

const related = getRelatedPosts(post, 3);
---

<BaseLayout
  title={post.seo.title}
  description={post.seo.description}
  ogImage={post.seo.ogImage || undefined}
  locale="en"
  tenantName={tenantName}
  tenantLogo={tenant?.storefront?.logo_url}
  themeCSS={themeCSS}
  phone={tenant?.phone}
>
  <BlogPostComponent
    post={post}
    locale="en"
    relatedPosts={related}
    tenantName={tenantName}
  />
</BaseLayout>
