---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import FeaturedProducts from '../components/FeaturedProducts.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import { resolveTenant, getThemeCSS } from '../lib/tenant';
import { getStorefrontProducts, getStorefrontCategories } from '../lib/products';
import { getBrands, type StorefrontBrand } from '../lib/brands';
import { t } from '../i18n';
import type { Locale } from '../i18n';

const locale: Locale = 'he';

// Resolve tenant — will use PUBLIC_DEFAULT_TENANT from env
let tenant = null;
let products: any[] = [];
let categories: Awaited<ReturnType<typeof getStorefrontCategories>> = [];
let topBrands: StorefrontBrand[] = [];

try {
  tenant = await resolveTenant();
  if (tenant) {
    const result = await getStorefrontProducts(tenant.id, { limit: 8 });
    products = result.products;
    categories = await getStorefrontCategories(tenant.id);
    const allBrands = await getBrands(tenant.id);
    topBrands = allBrands.sort((a, b) => b.product_count - a.product_count).slice(0, 8);
  }
} catch (e) {
  console.warn('Supabase not connected:', (e as Error).message);
}

const tenantName = tenant?.name ?? 'Optic Up';
const themeCSS = tenant ? getThemeCSS(tenant.storefront.theme) : '';
const seoTitle = tenant?.storefront.seo?.title ?? tenantName;
const seoDesc = tenant?.storefront.seo?.description ?? '';
---

<BaseLayout
  title={seoTitle}
  description={seoDesc}
  locale={locale}
  tenantName={tenantName}
  tenantLogo={tenant?.storefront.logo_url}
  themeCSS={themeCSS}
  phone={tenant?.phone}
>
  <HeroSection locale={locale} tenantName={tenantName} />
  <FeaturedProducts locale={locale} products={products} />
  <CategoryGrid locale={locale} categories={categories} />

  {/* Top brands section */}
  {topBrands.length > 0 && (
    <section class="py-14 sm:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl sm:text-3xl font-bold text-gray-900">
            {t(locale, 'brands.title')}
          </h2>
          <a
            href="/brands"
            class="text-sm font-medium hover:underline"
            style="color: var(--color-primary);"
          >
            {t(locale, 'brands.browseAll')} &rarr;
          </a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
          {topBrands.map((brand) => (
            <a
              href={`/brands/${brand.slug}`}
              class="flex items-center gap-3 p-4 bg-white rounded-xl border border-gray-200 hover:shadow-md hover:border-gray-300 transition-all"
            >
              <div
                class="w-10 h-10 rounded-full flex items-center justify-center text-white text-sm font-bold shrink-0"
                style="background: var(--color-primary);"
              >
                {brand.brand_name.charAt(0).toUpperCase()}
              </div>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-gray-900 truncate">{brand.brand_name}</p>
                <p class="text-xs text-gray-400">{brand.product_count} {t(locale, 'brands.productsCount')}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
