---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { resolveTenant, getThemeCSS } from '../../lib/tenant';
import { getStorefrontProducts, getStorefrontBrands, getStorefrontCategories } from '../../lib/products';
import { t } from '../../i18n';
import type { Locale } from '../../i18n';

const locale: Locale = 'he';

const url = Astro.url;
const brand = url.searchParams.get('brand') || undefined;
const category = url.searchParams.get('category') || undefined;
const search = url.searchParams.get('q') || undefined;
const sort = (url.searchParams.get('sort') as 'newest' | 'price_asc' | 'price_desc' | 'brand') || 'newest';
const page = parseInt(url.searchParams.get('page') || '1');
const perPage = 24;

let tenant = null;
let products: any[] = [];
let total = 0;
let brands: any[] = [];
let categories: any[] = [];

try {
  tenant = await resolveTenant();
  if (tenant) {
    const result = await getStorefrontProducts(tenant.id, {
      limit: perPage,
      offset: (page - 1) * perPage,
      brand,
      category,
      search,
      sort
    });
    products = result.products;
    total = result.total;
    brands = await getStorefrontBrands(tenant.id, category);
    categories = await getStorefrontCategories(tenant.id);
  }
} catch (e) {
  console.warn('Supabase error:', (e as Error).message);
}

const tenantName = tenant?.name ?? 'Optic Up';
const themeCSS = tenant ? getThemeCSS(tenant.storefront.theme) : '';
const totalPages = Math.ceil(total / perPage);
const pageTitle = search
  ? `${t(locale, 'products.searchResults')}: ${search}`
  : category
    ? `${category} — ${tenantName}`
    : `${t(locale, 'nav.products')} — ${tenantName}`;

function buildUrl(params: Record<string, string | undefined>) {
  const u = new URL(url);
  Object.entries(params).forEach(([k, v]) => {
    if (v) u.searchParams.set(k, v);
    else u.searchParams.delete(k);
  });
  return u.pathname + u.search;
}

// Pre-compute pagination to avoid template parsing issues with < operator
const pageNumbers: number[] = [];
const maxPages = Math.min(totalPages, 7);
for (let i = 0; i < maxPages; i++) {
  if (totalPages <= 7) {
    pageNumbers.push(i + 1);
  } else if (page <= 4) {
    pageNumbers.push(i + 1);
  } else if (page >= totalPages - 3) {
    pageNumbers.push(totalPages - 6 + i);
  } else {
    pageNumbers.push(page - 3 + i);
  }
}
const showPrev = page > 1;
const showNext = page < totalPages;
const hasPagination = totalPages > 1;
---

<BaseLayout
  title={pageTitle}
  description={`${t(locale, 'products.browseAll')} — ${tenantName}`}
  locale={locale}
  tenantName={tenantName}
  tenantLogo={tenant?.storefront.logo_url}
  themeCSS={themeCSS}
  phone={tenant?.phone}
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-gray-700">{t(locale, 'nav.home')}</a>
      <span class="mx-2">/</span>
      {category ? (
        <Fragment>
          <a href="/products" class="hover:text-gray-700">{t(locale, 'nav.products')}</a>
          <span class="mx-2">/</span>
          <span class="text-gray-900">{category}</span>
        </Fragment>
      ) : (
        <span class="text-gray-900">{t(locale, 'nav.products')}</span>
      )}
    </nav>

    <!-- Page title + search -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-bold text-gray-900">
          {search ? `${t(locale, 'products.searchResults')}: "${search}"` : category ?? t(locale, 'nav.products')}
        </h1>
        <p class="text-gray-500 mt-1">
          {total} {t(locale, 'products.items')}
        </p>
      </div>

      <!-- Search bar -->
      <form method="get" action="/products" class="flex gap-2 w-full sm:w-auto">
        <input
          type="text"
          name="q"
          value={search ?? ''}
          placeholder={t(locale, 'products.searchPlaceholder')}
          class="w-full sm:w-64 px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
        <button type="submit" class="px-4 py-2 rounded-lg text-white text-sm font-medium" style="background: var(--color-primary);">
          {t(locale, 'products.search')}
        </button>
      </form>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Sidebar filters -->
      <aside class="w-full lg:w-56 shrink-0">
        <!-- Sort -->
        <div class="mb-6">
          <h3 class="text-sm font-semibold text-gray-900 mb-3">{t(locale, 'products.sort')}</h3>
          <div class="flex flex-wrap gap-2 lg:flex-col">
            {[
              { val: 'newest', label: t(locale, 'products.sortNewest') },
              { val: 'price_asc', label: t(locale, 'products.sortPriceAsc') },
              { val: 'price_desc', label: t(locale, 'products.sortPriceDesc') },
              { val: 'brand', label: t(locale, 'products.sortBrand') },
            ].map((s) => (
              <a
                href={buildUrl({ sort: s.val, page: undefined })}
                class:list={[
                  'text-sm px-3 py-1.5 rounded-full border transition-colors',
                  sort === s.val
                    ? 'border-gray-900 bg-gray-900 text-white'
                    : 'border-gray-300 text-gray-600 hover:border-gray-500'
                ]}
              >
                {s.label}
              </a>
            ))}
          </div>
        </div>

        <!-- Category filter -->
        {categories.length > 0 && (
          <div class="mb-6">
            <h3 class="text-sm font-semibold text-gray-900 mb-3">{t(locale, 'products.categories')}</h3>
            <div class="flex flex-col gap-1">
              <a
                href={buildUrl({ category: undefined, page: undefined })}
                class:list={[
                  'text-sm px-3 py-1.5 rounded transition-colors',
                  !category ? 'bg-gray-100 font-medium text-gray-900' : 'text-gray-600 hover:bg-gray-50'
                ]}
              >
                {t(locale, 'products.allCategories')}
              </a>
              {categories.map((cat: any) => (
                <a
                  href={buildUrl({ category: cat.name, page: undefined })}
                  class:list={[
                    'text-sm px-3 py-1.5 rounded transition-colors flex justify-between',
                    category === cat.name ? 'bg-gray-100 font-medium text-gray-900' : 'text-gray-600 hover:bg-gray-50'
                  ]}
                >
                  <span>{cat.name}</span>
                  <span class="text-gray-400">{cat.count}</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Brand filter -->
        {brands.length > 0 && (
          <div class="mb-6">
            <h3 class="text-sm font-semibold text-gray-900 mb-3">{t(locale, 'products.brands')}</h3>
            <div class="flex flex-col gap-1 max-h-64 overflow-y-auto">
              <a
                href={buildUrl({ brand: undefined, page: undefined })}
                class:list={[
                  'text-sm px-3 py-1.5 rounded transition-colors',
                  !brand ? 'bg-gray-100 font-medium text-gray-900' : 'text-gray-600 hover:bg-gray-50'
                ]}
              >
                {t(locale, 'products.allBrands')}
              </a>
              {brands.map((b: any) => (
                <a
                  href={buildUrl({ brand: b.brand_name, page: undefined })}
                  class:list={[
                    'text-sm px-3 py-1.5 rounded transition-colors flex justify-between',
                    brand === b.brand_name ? 'bg-gray-100 font-medium text-gray-900' : 'text-gray-600 hover:bg-gray-50'
                  ]}
                >
                  <span>{b.brand_name}</span>
                  <span class="text-gray-400">{b.count}</span>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- Active filters reset -->
        {(brand || category || search) && (
          <a
            href="/products"
            class="inline-flex items-center gap-1 text-sm text-red-600 hover:text-red-700"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
            {t(locale, 'products.clearFilters')}
          </a>
        )}
      </aside>

      <!-- Product grid -->
      <div class="flex-1">
        {products.length > 0 ? (
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
            {products.map((product: any) => (
              <ProductCard locale={locale} product={product} />
            ))}
          </div>
        ) : (
          <div class="text-center py-16">
            <p class="text-gray-500 text-lg">{t(locale, 'products.noResults')}</p>
            <a href="/products" class="mt-4 inline-block text-sm underline" style="color: var(--color-primary);">
              {t(locale, 'products.clearFilters')}
            </a>
          </div>
        )}

        <!-- Pagination -->
        {hasPagination && (
          <nav class="flex items-center justify-center gap-2 mt-10">
            {showPrev && (
              <a
                href={buildUrl({ page: String(page - 1) })}
                class="px-3 py-2 rounded-lg border border-gray-300 text-sm text-gray-700 hover:bg-gray-50"
              >
                {t(locale, 'products.prev')}
              </a>
            )}

            {pageNumbers.map((p) => (
              <a
                href={buildUrl({ page: String(p) })}
                class:list={[
                  'px-3 py-2 rounded-lg text-sm font-medium',
                  p === page
                    ? 'text-white'
                    : 'border border-gray-300 text-gray-700 hover:bg-gray-50'
                ]}
                style={p === page ? 'background: var(--color-primary);' : ''}
              >
                {p}
              </a>
            ))}

            {showNext && (
              <a
                href={buildUrl({ page: String(page + 1) })}
                class="px-3 py-2 rounded-lg border border-gray-300 text-sm text-gray-700 hover:bg-gray-50"
              >
                {t(locale, 'products.next')}
              </a>
            )}
          </nav>
        )}
      </div>
    </div>
  </div>
</BaseLayout>
