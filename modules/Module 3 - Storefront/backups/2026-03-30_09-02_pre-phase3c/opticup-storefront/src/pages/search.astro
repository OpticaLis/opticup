---
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { resolveTenant, getThemeCSS } from '../lib/tenant';
import { getStorefrontProducts } from '../lib/products';
import { t } from '../i18n';
import type { Locale } from '../i18n';

const locale: Locale = 'he';

const url = Astro.url;
const query = url.searchParams.get('q')?.trim() || '';

let tenant = null;
let products: any[] = [];
let total = 0;

try {
  tenant = await resolveTenant();
  if (tenant && query) {
    const result = await getStorefrontProducts(tenant.id, {
      search: query,
      limit: 40,
    });
    products = result.products;
    total = result.total;
  }
} catch (e) {
  console.warn('Supabase error:', (e as Error).message);
}

const tenantName = tenant?.name ?? 'Optic Up';
const themeCSS = tenant ? getThemeCSS(tenant.storefront.theme) : '';
---

<BaseLayout
  title={query ? `${t(locale, 'search.title')}: ${query}` : t(locale, 'search.title')}
  noindex={true}
  locale={locale}
  tenantName={tenantName}
  tenantLogo={tenant?.storefront.logo_url}
  themeCSS={themeCSS}
  phone={tenant?.phone}
>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-6">
      <a href="/" class="hover:text-gray-700">{t(locale, 'nav.home')}</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900">{t(locale, 'search.title')}</span>
    </nav>

    <!-- Search form -->
    <div class="max-w-xl mx-auto mb-10">
      <h1 class="text-3xl font-bold text-gray-900 text-center mb-6">
        {t(locale, 'search.heading')}
      </h1>
      <form method="get" action="/search" class="flex gap-2">
        <input
          type="text"
          name="q"
          value={query}
          placeholder={t(locale, 'products.searchPlaceholder')}
          autofocus
          class="flex-1 px-4 py-3 border border-gray-300 rounded-xl text-base focus:outline-none focus:ring-2 focus:ring-blue-500"
        />
        <button
          type="submit"
          class="px-6 py-3 rounded-xl text-white font-medium text-base"
          style="background: var(--color-primary);"
        >
          {t(locale, 'products.search')}
        </button>
      </form>
    </div>

    {/* Results */}
    {query ? (
      products.length > 0 ? (
        <div>
          <p class="text-gray-500 mb-6">
            {total} {t(locale, 'products.items')} — "{query}"
          </p>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
            {products.map((product: any) => (
              <ProductCard locale={locale} product={product} />
            ))}
          </div>
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-gray-500 text-lg mb-2">
            {t(locale, 'search.noResults')} "{query}"
          </p>
          <p class="text-gray-400 text-sm mb-6">{t(locale, 'search.tryAgain')}</p>
          <a href="/products" class="inline-block text-sm underline" style="color: var(--color-primary);">
            {t(locale, 'products.browseAll')}
          </a>
        </div>
      )
    ) : null}
  </div>
</BaseLayout>
