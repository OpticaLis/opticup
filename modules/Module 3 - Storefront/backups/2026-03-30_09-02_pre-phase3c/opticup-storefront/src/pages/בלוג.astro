---
/**
 * Hebrew Blog Index — /בלוג/
 * Lists all Hebrew blog posts sorted by date (newest first).
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getAllPosts } from '../data/blog-posts';
import { resolveTenant } from '../lib/tenant';

const tenant = await resolveTenant();
const tenantName = tenant?.name || '';
const themeCSS = tenant?.storefront?.theme
  ? Object.entries(tenant.storefront.theme).map(([k, v]) => `--color-${k}: ${v};`).join(' ')
  : '';

const posts = getAllPosts('he').sort((a, b) => b.date.localeCompare(a.date));
const title = `הבלוג של ${tenantName}`;
---

<BaseLayout
  title={title}
  description={`מאמרים ומדריכים בנושאי אופטיקה, משקפיים ועדשות מגע מ${tenantName}`}
  locale="he"
  tenantName={tenantName}
  tenantLogo={tenant?.storefront?.logo_url}
  themeCSS={themeCSS}
  phone={tenant?.phone}
>
  <div class="max-w-6xl mx-auto px-4 py-8" dir="rtl">
    <!-- Hero -->
    <div class="text-center mb-10">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">{title}</h1>
      <p class="text-gray-600 text-lg">מאמרים, מדריכים וטיפים מעולם האופטיקה</p>
    </div>

    <!-- Posts count -->
    <p class="text-sm text-gray-500 mb-6">{posts.length} מאמרים</p>

    <!-- Posts grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map(post => (
        <BlogCard post={post} locale="he" />
      ))}
    </div>

    {posts.length === 0 && (
      <div class="text-center py-20 text-gray-400">
        <p class="text-xl">אין מאמרים עדיין</p>
      </div>
    )}
  </div>

  <!-- hreflang -->
  <link rel="alternate" hreflang="he" href="/%D7%91%D7%9C%D7%95%D7%92/" slot="head" />
  <link rel="alternate" hreflang="en" href="/en/blog/" slot="head" />
  <link rel="alternate" hreflang="ru" href="/ru/blog/" slot="head" />
  <link rel="alternate" hreflang="x-default" href="/%D7%91%D7%9C%D7%95%D7%92/" slot="head" />
</BaseLayout>
